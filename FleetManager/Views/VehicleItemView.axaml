<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:FleetManager.Models"
             xmlns:vm="clr-namespace:FleetManager.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="FleetManager.Views.VehicleItemView"
             x:DataType="vm:VehicleItemViewModel">
    
    <Border Padding="12"
            Margin="6"
            BorderBrush="Gray"
            BorderThickness="1"
            CornerRadius="6">

        <StackPanel Spacing="6">

            <TextBlock Text="{Binding Model.Name}" FontSize="16" FontWeight="Bold"/>
            <TextBlock Text="{Binding Model.FuelLevel, StringFormat='Fuel: {0}%'}"/>
            <TextBlock Text="{Binding Model.Status, StringFormat='Status: {0}'}"/>

            <StackPanel Orientation="Horizontal" Spacing="5">
                <Button Content="Available"
                        Command="{Binding ChangeStatusCommand}"
                        CommandParameter="{x:Static models:VehicleStatus.Available}"/>
                <Button Content="InRoute"
                        Command="{Binding ChangeStatusCommand}"
                        CommandParameter="{x:Static models:VehicleStatus.InRoute}"/>
                <Button Content="Service"
                        Command="{Binding ChangeStatusCommand}"
                        CommandParameter="{x:Static models:VehicleStatus.Service}"/>
                
                <Button Content="Refuel" 
                        Command="{Binding RefuelCommand}"
                        Background="SteelBlue" 
                        Foreground="White"/>
            </StackPanel>

        </StackPanel>

    </Border>
    
</UserControl>